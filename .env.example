# Required
YANDEX_TRACKER_TOKEN=replace_me
# Set exactly one of the following org identifiers:
YANDEX_TRACKER_ORG_ID=replace_me
# YANDEX_TRACKER_CLOUD_ORG_ID=replace_me

# Optional
YANDEX_TRACKER_TOKEN_TYPE=OAuth
YANDEX_TRACKER_BASE_URL=https://api.tracker.yandex.net
YANDEX_TRACKER_TIMEOUT_SECONDS=30
YANDEX_TRACKER_RETRIES=2
YANDEX_TRACKER_USER_AGENT=yandex-tracker-mcp/0.1.0
